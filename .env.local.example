# Supabase — Analytics database
# Public URL (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key (safe to expose to client — used for client components if any)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to the client. Used only in server components/actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
